# Copy this file to `.env` and adjust. Values here are safe dev defaults.
# Anything already set in the real environment overrides the .env file.

# --- HTTP ---
PORT=8080

# --- Database (libpq connection string) ---
DATABASE_URL=host=localhost port=5432 dbname=authdb user=postgres password=postgres

# --- Password hashing ---
# The pepper is a server-wide secret that is mixed into every password hash.
# It lives ONLY here, never in the database. Generate a long random value:
#   openssl rand -hex 32
PASSWORD_PEPPER=dev-only-insecure-pepper-change-me
PBKDF2_ITERATIONS=200000

# --- WebAuthn / passkeys ---
# RP_ID must be the registrable domain the site is served from (no scheme/port).
# Use "localhost" for local development.
RP_NAME=lootopia
RP_ID=localhost
# ORIGIN must match exactly what the browser sends (scheme + host + port).
ORIGIN=http://localhost:8080

# --- Links in emails ---
PUBLIC_BASE_URL=http://localhost:8080

# --- Object storage (RustFS / S3-compatible) ---
# Start local RustFS with: docker compose up -d rustfs
# Console: http://localhost:9001  (rustfsadmin / rustfsadmin)
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
S3_BUCKET=lootopia
S3_REGION=us-east-1
S3_KEY_PREFIX=lootopia
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/lootopia
# Production: point at real S3 and unset S3_ENDPOINT, or use your CDN:
# S3_PUBLIC_BASE_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# --- Lifetimes (seconds) ---
SESSION_TTL_SECONDS=86400
EMAIL_VERIFY_TTL_SECONDS=86400
CEREMONY_TTL_SECONDS=300

# Require a verified email before login completes (true/false).
REQUIRE_VERIFIED_EMAIL=true

# --- SMTP (optional) ---
# Leave SMTP_HOST empty to run in "dev email" mode, where verification links
# are printed to the server's stdout instead of being emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@localhost

# --- JWT ---
# openssl rand -hex 32
JWT_SECRET=dev-only-insecure-jwt-secret-change-me

# --- Live events (Kafka + Redis) ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=live-events
REDIS_URL=redis://localhost:6379
